# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STAEL_STRIPE_ACCOUNT_ID=acct_...
# Auto-collect Vyn Studio's 20% platform fee on every Cal.com BOOKING_PAID.
# Cal.com creates direct charges on Stael's connected account, so this
# triggers a connected→platform transfer pulling 20% from each charge
# back to the platform. Set to 'true' to enable.
STAEL_AUTO_SPLIT_ENABLED=false
# Optional fee override (basis points). 2000 = 20%. Default 2000.
# VYN_PLATFORM_FEE_BPS=2000
# Optional platform acct override; otherwise fetched at runtime.
# VYN_PLATFORM_ACCOUNT_ID=acct_...

# Admin-only endpoints (connect-onboard)
# Generate a long random value (e.g. `openssl rand -hex 32`).
ADMIN_SECRET=changeme-long-random-string

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Google (service account with domain-wide delegation for Calendar)
# Paste the full service-account JSON as a single-line string.
# The service account's client_id must be authorized in Google Admin Console
# → Security → API controls → Domain-wide delegation for scope:
#   https://www.googleapis.com/auth/calendar
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}
GOOGLE_IMPERSONATE=hello@staelfogarty.com
GOOGLE_CALENDAR_ID=primary

# Resend (transactional email)
RESEND_API_KEY=re_...

# Notification recipients
STAEL_EMAIL=hello@staelfogarty.com
VYN_EMAIL=hello@vyn.studio

# Netlify sets URL automatically in production; override for local dev if needed.
# URL=https://staelfogarty.com
